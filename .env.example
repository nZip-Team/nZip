HOST=http://localhost:3000
PORT=3000

# SESSION_STORE can be "sqlite" or "redis"
# sqlite: SQLite database for session storage (default, works across multiple processes on same machine)
# redis: Redis for external session storage (requires REDIS_URL)
SESSION_STORE=sqlite

# Redis connection URL (only used if SESSION_STORE=redis)
# Format: redis://username:password@localhost:6379
REDIS_URL=

API_URL=
IMAGE_URL=

CONCURRENT_IMAGE_DOWNLOADS=16

# Analytics script tag (HTML string that will be inserted directly into <head>)
# Leave empty to disable analytics
ANALYTICS=

# development or production
NODE_ENV=development
