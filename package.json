{
  "name": "nzip",
  "version": "1.13.0-beta",
  "type": "module",
  "scripts": {
    "start": "bun Main.ts",
    "dev": "bun Main.ts",
    "prebuild": "bun Scripts/pre-build.ts",
    "build": "bun Scripts/build.ts",
    "postbuild": "bun Scripts/post-build.ts",
    "build:core": "cd Core && go build -ldflags=\"-s -w\" -o nzip-core .",
    "build:docker": "bun Scripts/build-docker.ts",
    "dev:docker": "docker compose -f compose.dev.yml up --build",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@icebrick/nhget": "^1.0.5",
    "bun": "^1.3.10",
    "cron": "^4.4.0",
    "hono": "^4.12.2",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/yazl": "^3.3.0",
    "prettier": "^3.8.1"
  }
}
